## RPM spec for ProtonDrive-Linux.
## Filled in by the release workflow (sed) for {VERSION}.

Name:           protondrive-linux
Version:        {VERSION}
Release:        1%{?dist}
Summary:        Unofficial native Linux client for Proton Drive
License:        GPL-3.0-or-later
URL:            https://github.com/0xnullsect0r/ProtonDrive-Linux
Source0:        %{name}-%{version}.tar.gz
BuildRequires:  gcc, make, golang, pkgconfig
BuildRequires:  pkgconfig(gtk4), pkgconfig(libadwaita-1)
BuildRequires:  pkgconfig(libsecret-1), pkgconfig(openssl)
BuildRequires:  pkgconfig(webkit2gtk-4.1)
BuildRequires:  systemd-rpm-macros
Requires:       libsecret, gtk4, libadwaita, webkit2gtk4.1
Recommends:     gnome-shell-extension-appindicator

%description
Unofficial native Linux client for Proton Drive. Bidirectional sync of a real
local folder against your Proton Drive, GTK4 setup wizard and a system-tray
icon for GNOME, KDE Plasma, Budgie and Cinnamon.

%global debug_package %{nil}

%prep
%autosetup -n ProtonDrive-Linux-%{version}

%build
cargo build --release --locked
cd crates/protondrive-hv && cargo build --release

%install
install -Dm0755 target/release/protondrive       %{buildroot}%{_bindir}/protondrive
install -Dm0755 target/release/protondrived      %{buildroot}%{_bindir}/protondrived
install -Dm0755 target/release/protondrive-cli   %{buildroot}%{_bindir}/protondrive-cli
install -Dm0755 crates/protondrive-hv/target/release/protondrive-hv %{buildroot}%{_bindir}/protondrive-hv
# Go-CGO bridge .so produced by build.rs — installed into the libdir and
# located at runtime via the rpath embedded in the binaries
# (-Wl,-rpath,$ORIGIN/../lib).
_BRIDGE_SO=$(find target/release/build -maxdepth 4 -name libprotonbridge.so | head -n1)
install -Dm0755 "$_BRIDGE_SO" %{buildroot}%{_libdir}/libprotonbridge.so
install -Dm0644 packaging/desktop/me.proton.drive.Linux.desktop      %{buildroot}%{_datadir}/applications/me.proton.drive.Linux.desktop
install -Dm0644 packaging/desktop/me.proton.drive.Linux.metainfo.xml %{buildroot}%{_metainfodir}/me.proton.drive.Linux.metainfo.xml
install -Dm0644 data/icons/me.proton.drive.Linux.svg                 %{buildroot}%{_datadir}/icons/hicolor/scalable/apps/me.proton.drive.Linux.svg
install -Dm0644 packaging/systemd/protondrive.service                %{buildroot}%{_userunitdir}/protondrive.service
install -Dm0644 packaging/tmpfiles.d/protondrive.conf                %{buildroot}%{_tmpfilesdir}/protondrive.conf

%files
%license LICENSE
%doc README.md
%{_bindir}/protondrive
%{_bindir}/protondrived
%{_bindir}/protondrive-cli
%{_bindir}/protondrive-hv
%{_libdir}/libprotonbridge.so
%{_datadir}/applications/me.proton.drive.Linux.desktop
%{_metainfodir}/me.proton.drive.Linux.metainfo.xml
%{_datadir}/icons/hicolor/scalable/apps/me.proton.drive.Linux.svg
%{_userunitdir}/protondrive.service
%{_tmpfilesdir}/protondrive.conf

%changelog
* Thu Apr 30 2026 ProtonDrive-Linux contributors - {VERSION}-1
- Release {VERSION}
